# sBTC Portfolio Tracker Environment Configuration
# Copy this file to .env.local and fill in your values

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================
# Options: mainnet | testnet
NEXT_PUBLIC_NETWORK=testnet

# =============================================================================
# API ENDPOINTS
# =============================================================================
# Hiro API (get your key at https://platform.hiro.so)
NEXT_PUBLIC_HIRO_API_KEY=

# Mainnet endpoints
NEXT_PUBLIC_MAINNET_API_URL=https://api.hiro.so
NEXT_PUBLIC_MAINNET_EXPLORER_URL=https://explorer.hiro.so

# Testnet endpoints
NEXT_PUBLIC_TESTNET_API_URL=https://api.testnet.hiro.so
NEXT_PUBLIC_TESTNET_EXPLORER_URL=https://explorer.hiro.so/?chain=testnet

# =============================================================================
# SBTC CONTRACT ADDRESSES
# =============================================================================
# Mainnet sBTC contracts
NEXT_PUBLIC_MAINNET_SBTC_TOKEN=SM3VDXK3WZZSA84XXFKAFAF15NNZX32CTSG82JFQ4.sbtc-token
NEXT_PUBLIC_MAINNET_SBTC_DEPOSIT=SM3VDXK3WZZSA84XXFKAFAF15NNZX32CTSG82JFQ4.sbtc-deposit

# Testnet sBTC contracts (official from Stacks docs)
NEXT_PUBLIC_TESTNET_SBTC_TOKEN=ST1F7QA2MDF17S807EPA36TSS8AMEFY4KA9TVGWXT.sbtc-token
NEXT_PUBLIC_TESTNET_SBTC_DEPOSIT=ST1F7QA2MDF17S807EPA36TSS8AMEFY4KA9TVGWXT.sbtc-deposit

# =============================================================================
# DEFI PROTOCOL CONTRACTS (Mainnet)
# =============================================================================
# ALEX DEX
NEXT_PUBLIC_ALEX_ROUTER=SP102V8P0F7JX67ARQ77WEA3D3CFB5XW39REDT0AM.amm-pool-v2-01

# Zest Protocol (Lending)
NEXT_PUBLIC_ZEST_POOL=SP2VCQJGH7PHP2DJK7Z0V48AGBHQAW3R3ZW1QF4N.pool-v1-0

# BitFlow DEX
NEXT_PUBLIC_BITFLOW_ROUTER=SPQC38PW542ELJ5KNAC4BSJA7BXAK8ZFXY3JT9TP.stableswap-core-v-1-2

# StackingDAO
NEXT_PUBLIC_STACKING_DAO=SP4SZE494VC2YC5JYG7AYFQ44F5Q4PYV7DVMDPBG.stacking-dao-core-v1

# Velar
NEXT_PUBLIC_VELAR_ROUTER=SP1Y5YSTAHZ88XYK1VPDH24GY0HPX5J4JECTMY4A1.velar-v1

# =============================================================================
# PRICE DATA
# =============================================================================
# CoinGecko API (optional, for price data)
NEXT_PUBLIC_COINGECKO_API_URL=https://api.coingecko.com/api/v3

# =============================================================================
# FEATURE FLAGS
# =============================================================================
NEXT_PUBLIC_ENABLE_DEFI_TRACKING=true
NEXT_PUBLIC_ENABLE_PRICE_CHARTS=true
NEXT_PUBLIC_ENABLE_TRANSACTION_HISTORY=true
NEXT_PUBLIC_ENABLE_PORTFOLIO_ANALYTICS=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=false

# =============================================================================
# APP CONFIGURATION
# =============================================================================
NEXT_PUBLIC_APP_NAME="sBTC Portfolio Tracker"
NEXT_PUBLIC_APP_DESCRIPTION="Track your sBTC holdings, DeFi positions, and portfolio analytics"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cache TTL in seconds
NEXT_PUBLIC_CACHE_TTL_BALANCE=30
NEXT_PUBLIC_CACHE_TTL_TRANSACTIONS=60
NEXT_PUBLIC_CACHE_TTL_PRICES=300
NEXT_PUBLIC_CACHE_TTL_DEFI=120

# =============================================================================
# RATE LIMITING
# =============================================================================
# Max requests per minute (to avoid API throttling)
NEXT_PUBLIC_MAX_REQUESTS_PER_MINUTE=60
